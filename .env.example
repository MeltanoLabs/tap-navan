# Navan TMC API Configuration
# Copy this file to .env and fill in your actual values.
# Credentials are issued per company by Navan — generate them in the
# Navan Admin Dashboard under Settings > Integrations.

# Required: OAuth2 client ID
TAP_NAVAN_CLIENT_ID=your_client_id_here

# Required: OAuth2 client secret (decrypt the RSA-encrypted value Navan
# provides before setting this — see the TMC integration docs for the
# openssl command).
TAP_NAVAN_CLIENT_SECRET=your_decrypted_client_secret_here

# Optional: Earliest booking creation date to sync (ISO 8601).
# Bookings created before this date will be ignored.
TAP_NAVAN_START_DATE=2024-01-01T00:00:00Z

# Optional: API base URL.
#   Production US (default): https://api.navan.com
#   Production EU:           https://app-fra.navan.com
#   Staging:                 https://staging-prime.tripactions.com
TAP_NAVAN_API_URL=https://api.navan.com
